generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Groupe {
  id      Int      @id @default(autoincrement())
  nom     String   @unique // TA1, TA2, TB1, TB2
  users   User[]
  devoirs Devoir[]
  cours   Cours[]
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  password  String
  role      String   @default("etudiant") // etudiant | delegue | admin
  valide    Boolean  @default(false)
  createdAt DateTime @default(now())

  groupe   Groupe @relation(fields: [groupeId], references: [id])
  groupeId Int

  notes              Note[]
  devoirsCreees      Devoir[]           @relation("AuteurDevoir")
  pushSubscriptions  PushSubscription[]
  messages           Message[]
  reactions          Reaction[]
  passwordResets     PasswordReset[]
}

model PushSubscription {
  id       Int    @id @default(autoincrement())
  endpoint String @unique
  p256dh   String
  auth     String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}

model Devoir {
  id          Int      @id @default(autoincrement())
  titre       String
  matiere     String
  description String?
  dateLimite  DateTime
  createdAt   DateTime @default(now())

  groupe   Groupe @relation(fields: [groupeId], references: [id])
  groupeId Int

  auteur   User @relation("AuteurDevoir", fields: [auteurId], references: [id])
  auteurId Int
}

model Note {
  id          Int      @id @default(autoincrement())
  matiere     String
  valeur      Float
  coefficient Float    @default(1)
  createdAt   DateTime @default(now())

  user   User @relation(fields: [userId], references: [id])
  userId Int
}

model Channel {
  id          Int       @id @default(autoincrement())
  nom         String    @unique
  description String?
  type        String    @default("custom") // general | groupe | custom
  createdAt   DateTime  @default(now())
  messages    Message[]
}

model Message {
  id        Int       @id @default(autoincrement())
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  auteur   User    @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  auteurId Int

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId Int

  replyTo   Message?   @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replyToId Int?
  replies   Message[]  @relation("MessageReply")

  reactions Reaction[]
}

model Reaction {
  id        Int     @id @default(autoincrement())
  emoji     String

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId Int

  @@unique([userId, messageId, emoji])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}

model Cours {
  id         Int    @id @default(autoincrement())
  matiere    String
  jour       String
  heureDebut String
  heureFin   String
  salle      String?
  prof       String?

  groupe   Groupe @relation(fields: [groupeId], references: [id])
  groupeId Int
}
